<Login>:
    name:"logn"
    id:ln
    canvas.before:
        Color:
            rgba:(1,1,1,0.7)
        Rectangle: 
            size:self.size
            pos:self.pos
    Loginbox: 
<Loginbox>:
    size_hint: (0.5,0.7)
    orientation: 'vertical'
    padding:10
    spacing:10
    pos_hint: {'center_x':0.5,'center_y':0.5}
    Image:
        source:"logopur.png"
        size_hint: (0.5,0.5)
        pos_hint: {'center_x':0.5,'center_y':0.5}
    Label:
        id:mn
        text: 'Admin Login'
        font_size:50
        pos_hint: {'center_x':0.5,'center_y':0.5}
        size_hint: (0.8,0.2)
        color:(0,0,0,0.9)
        valign: 'bottom'
        halign: 'center'
        bold: True
        italic: True
        canvas.after: 
            Color: 
                rgba: (0,0,0,0.9)
            Line:
                points:self.x,self.y,self.right,self.y
                width:0.5
    GridLayout:
        spacing:10
        padding:15
        cols:2
        rows:2
        pos_hint: {'center_x':0.5,'center_y':0.5}
        size_hint: (0.8,0.5)
        canvas.before:
            Color:
                rgba:(1,1,1,0.5)
            RoundedRectangle: 
                size:self.size
                pos:self.pos
                radius:[30] 
        Image:
            source:"person.png"
        TextInput:
            id:user
            font_size:20 
            valign:"bottom"
            halign:"center"
            background_color: (0,0,0,0)
            hint_text: "username"
            foreground_color: (0,0,0,1)
            size_hint:(1,0.2)
            multiline:False  
            canvas.after: 
                Color: 
                    rgba: (0,0,0,1)
                Line:
                    points:self.x,self.y,self.right,self.y
                    width:3
                                
        Image:
            source:"115681.png"
        TextInput:
            id:pswrd
            font_size:20 
            multiline:False
            valign:"bottom"
            halign:"center"
            hint_text: "password"
            size_hint:(1,0.2)
            password: True
            password_mask: '#'
            background_color: (0,0,0,0)
            foreground_color: (0,0,0,1)
            canvas.after: 
                Color: 
                    rgba: (0,0,0,1)
                Line:
                    points:self.x,self.y,self.right,self.y
                    width:3 

    Label:
        id:inter
        text: 'Worng Details'
        font_size:40
        pos_hint: {'center_x':0.5,'center_y':0.5}
        size_hint: (0.8,0.2)
        color:(1,0,0,0.9)
        valign: 'bottom'
        halign: 'center'
        bold: True
        italic: True
        disabled:True
        opacity: 0
                  
    Button:
        text:"login" 
        pos_hint: {'center_x':0.5,'center_y':0.5}
        size_hint: (0.5,0.2) 
        background_color: (0,0,0,0)
        on_press:
            root.parent.login(self,root)
        canvas.before: 
            Color: 
                rgba: (0.5,0,0,5)
            RoundedRectangle: 
                size:self.size
                pos:self.pos
                radius: [20]  
<Tabpl>:
    spacing:10
    padding:10
    pos:(0,0)
    canvas.before:
        RoundedRectangle:
            size:self.size
            pos:self.pos
    do_default_tab:False
    TabbedPanelItem:
        text:"HOME"
