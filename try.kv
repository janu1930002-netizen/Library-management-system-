<Bookupdelete>:
    id:std
    orientation: 'vertical'
    spacing: 20
    padding: 20
    size:root.size
    pos:root.pos
    id:student
    canvas.before:
        Rectangle: 
            size:self.size
            pos:self.pos
            source:"bg.png"
    GridLayout:
        rows:1
        cols:3
        size_hint: (1,0.1)
        pos_hint: {'center_x':0.5,'center_y':0.5}
        TextInput:
            id:bookcheck
            multiline: False
