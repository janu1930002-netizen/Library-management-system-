<Bookread>:
    id:std
    orientation: 'vertical'
    spacing: 20
    padding: 20
    size:root.size
    pos:root.pos
    id:student
    canvas.before:
        Rectangle: 
            size:self.size
            pos:self.pos
            source:"bg.png"
    GridLayout:
        rows:1
        cols:3
        size_hint: (1,0.1)
        pos_hint: {'center_x':0.5,'center_y':0.5}
        TextInput:
            id:bookcheck
            multiline: False
            hint_text: "Enter the Book_Id"
            input_filter: "int"
            pos_hint: {'center_x':0.5,'center_y':0.5}
            bold: True
            italic: True
            valign: 'bottom'
            halign: 'left'
            background_color: (1,1,1,0)
            color: (0,0,0,1)
            font_size: 20
            canvas.before:
                Color: 
                    rgb: (0,0,0)
                Line:
                    points:self.x,self.y,self.right,self.y
                    width: 2
        Button:
            text: 'Show'
            pos_hint: {'center_x':0.5,'center_y':0.5}
            size_hint: (0.5,0.4) 
            background_color: (0,0,0,0)
            canvas.before: 
                Color: 
                    rgba: (0.5,0,0,5)
                RoundedRectangle: 
                    size:self.size
                    pos:self.pos
                    radius: [20]  
            on_press:root.bcheck(self)
        Button:
            text: 'Back'
            pos_hint: {'center_x':0.5,'center_y':0.5}
            size_hint: (0.5,0.4) 
            background_color: (0,0,0,0)
            canvas.before: 
                Color: 
                    rgba: (0.5,0,0,5)
                RoundedRectangle: 
                    size:self.size
                    pos:self.pos
                    radius: [20]  
            on_press:
                root.back(self)
                root.parent.manager.current="home"


            
    Label:
        text:"BOOK DETAILS "
        id:header
        size_hint: (0.4,0.1)
        pos_hint: {'center_x':0.5,'center_y':0.5}
        bold: True
        italic: True
        opacity: 0
        disabled:True
        color: (0,0,0,1)
        font_size: 30
        canvas.before:
            Color: 
                rgb: (0,0,0)
            Line:
                points:self.x,self.y,self.right,self.y
                width: 5
    GridLayout:
        cols: 2
        rows:20
        opacity:0
        disabled:True
        id:container
        padding:10
        pos_hint: {'center_x':0.5,'center_y':0.5}
        canvas.before:
            Color:
                rgba: (1,1,1,0.6) 
            RoundedRectangle: 
                size:self.size
                pos:self.pos
                radius:[20] 
                
        Label:
            text: 'Book Name'
            size_hint: (0.5,0.1)
            pos_hint: {'center_x':0.5,'center_y':0.5}
            bold: True
            italic: True
            valign: 'bottom'
            halign: 'center'
            color: (0,0,0,1)
            font_size: 30
            canvas.before:
                Color: 
                    rgb: (0,0,0)
                Line:
                    points:self.x,self.y,self.right,self.y
                    width:1 
        TextInput:
            size_hint: (0.5,0.5)
            id:name
            readonly:True
            pos_hint: {'center_x':0.5,'center_y':0.5}
            bold: True
            italic: True
            valign: 'bottom'
            halign: 'left'
            background_color: (1,1,1,0)
            color: (0,0,0,1)
            font_size: 20
            canvas.before:
                Color: 
                    rgb: (0,0,0)
                Line:
                    points:self.x,self.y,self.right,self.y
