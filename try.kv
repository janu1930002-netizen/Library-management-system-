<Studentread>:
    id:std
    orientation: 'vertical'
    spacing: 20
    padding: 20
    size:root.size
    pos:root.pos
    id:student
    canvas.before:
        Rectangle: 
            size:self.size
            pos:self.pos
            source:"bg.png"
    GridLayout:
        rows:1
        cols:3
        size_hint: (1,0.1)
        pos_hint: {'center_x':0.5,'center_y':0.5}
        TextInput:
            id:stidcheck
            hint_text: "Enter the student Id"
            input_filter: "int"
            pos_hint: {'center_x':0.5,'center_y':0.5}
            bold: True
            italic: True
            valign: 'bottom'
            halign: 'left'
            background_color: (1,1,1,0)
            color: (0,0,0,1)
            font_size: 20
